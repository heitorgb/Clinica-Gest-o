{
  "name": "clinica-gestao-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node --preserve-symlinks-main ./node_modules/vite/bin/vite.js --host 0.0.0.0 --configLoader native",
    "build": "node --preserve-symlinks-main ./node_modules/typescript/bin/tsc -b && node --preserve-symlinks-main ./node_modules/vite/bin/vite.js build --configLoader native",
    "preview": "node --preserve-symlinks-main ./node_modules/vite/bin/vite.js preview --host 0.0.0.0 --configLoader native",
    "typecheck": "node --preserve-symlinks-main ./node_modules/typescript/bin/tsc -b"
  },
  "dependencies": {
    "lucide-react": "0.468.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "7.15.1"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "@types/react": "18.3.17",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "5.2.0",
    "autoprefixer": "10.5.0",
    "postcss": "8.5.15",
    "tailwindcss": "3.4.19",
    "typescript": "5.7.2",
    "vite": "7.3.3"
  }
}
