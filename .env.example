# Projeto
PROJECT_NAME=clinica-gestao
# Local ativo. Para producao, comente a linha local e descomente a linha marcada como Producao.
ENVIRONMENT=local
# Producao:
# ENVIRONMENT=production
APP_NAME=Clinica Gestao API
APP_DEBUG=true
# Producao:
# APP_DEBUG=false
API_V1_PREFIX=/api/v1

# URLs do ambiente ativo
PUBLIC_APP_URL=http://localhost:5180
PUBLIC_API_URL=http://localhost:8008/api/v1
# Producao:
# PUBLIC_APP_URL=https://clinica.orderup.com.br
# PUBLIC_API_URL=https://clinica.orderup.com.br/api/v1

# PostgreSQL usado pelo Docker Compose
POSTGRES_DB=clinica
POSTGRES_USER=clinica
POSTGRES_PASSWORD=clinica_dev_password
# Producao:
# POSTGRES_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE_DO_POSTGRES
# Porta publicada no servidor
POSTGRES_PORT=5434

# Backend
BACKEND_HOST=0.0.0.0
# Porta publicada no servidor
BACKEND_PORT=8008
# Porta interna do container da API
BACKEND_CONTAINER_PORT=8000
BACKEND_RELOAD_ARGS=
BACKEND_CORS_ORIGINS=http://localhost:5180,http://127.0.0.1:5180
# Producao:
# BACKEND_CORS_ORIGINS=https://clinica.orderup.com.br
JWT_SECRET_KEY=change_me_in_local_env_with_at_least_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Primeiro administrador local
FIRST_SUPERUSER_NAME=Administrador
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=admin12345
# Producao:
# FIRST_SUPERUSER_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE_DO_ADMIN

# Frontend
# Porta publicada no servidor
FRONTEND_PORT=5180
# Porta interna do container web
FRONTEND_CONTAINER_PORT=5180
VITE_APP_NAME=Clinica Gestao
VITE_API_BASE_URL=http://localhost:8008/api/v1
# Producao:
# VITE_API_BASE_URL=https://clinica.orderup.com.br/api/v1

# Integracoes futuras
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_API_VERSION=2023-06-01
WHATSAPP_API_TOKEN=

# Conector MCP para Claude
MCP_CONNECTOR_ENABLED=true
MCP_WRITE_TOOLS_ENABLED=false
MCP_AUDIT_ENABLED=true
MCP_AUTH_ENABLED=false
# Producao:
# MCP_AUTH_ENABLED=true
# Claude usa OAuth. Token direto fica apenas como fallback para testes fora do Claude.
MCP_AUTH_TOKEN=
MCP_ALLOW_QUERY_TOKEN=true
MCP_SERVER_NAME=clinica-gestao
